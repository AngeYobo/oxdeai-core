{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxdeai.org/schemas/v1/verification-envelope-v1.schema.json",
  "title": "OxDeAI VerificationEnvelopeV1",
  "description": "Portable envelope carrying snapshot bytes (base64) and audit events.",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "snapshot", "events"],
  "properties": {
    "formatVersion": { "type": "integer", "const": 1 },
    "snapshot": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "https://oxdeai.org/schemas/v1/audit-event.schema.json"
      }
    }
  }
}
