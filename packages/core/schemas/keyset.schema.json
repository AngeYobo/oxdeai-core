{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxdeai.org/schemas/v1/keyset.schema.json",
  "title": "OxDeAI KeySet",
  "description": "Issuer-scoped public key set for non-forgeable verification.",
  "$comment": "Version: OxDeAI protocol v1.2.0. Offline key distribution shape for kid/alg-based verification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["issuer", "version", "keys"],
  "properties": {
    "issuer": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kid", "alg", "public_key"],
        "properties": {
          "kid": { "type": "string", "minLength": 1 },
          "alg": { "type": "string", "enum": ["Ed25519", "HMAC-SHA256"] },
          "public_key": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["active", "retired", "revoked"] },
          "not_before": { "type": "integer", "minimum": 0 },
          "not_after": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
