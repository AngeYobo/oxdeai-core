{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxdeai.org/schemas/v1/authorization.schema.json",
  "title": "OxDeAI Authorization",
  "description": "Authorization artifact emitted by the policy engine.",
  "$comment": "Version: OxDeAI protocol v1.2.0. Public-key path uses Ed25519 with alg/kid/signature; legacy compatibility fields may coexist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auth_id",
    "issuer",
    "audience",
    "intent_hash",
    "state_hash",
    "policy_id",
    "decision",
    "issued_at",
    "expiry",
    "alg",
    "kid",
    "signature"
  ],
  "properties": {
    "authorization_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "auth_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "intent_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_version": { "type": "string", "minLength": 1 },
    "state_snapshot_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decision": { "type": "string", "enum": ["ALLOW", "DENY"] },
    "issued_at": { "type": "integer", "minimum": 0 },
    "expiry": { "type": "integer", "minimum": 0 },
    "alg": { "type": "string", "enum": ["Ed25519", "HMAC-SHA256"] },
    "kid": { "type": "string", "minLength": 1 },
    "nonce": { "type": "string" },
    "capability": { "type": "string" },
    "signature": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "integer", "minimum": 0 },
    "engine_signature": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
