{
  "name": "@oxdeai/conformance",
  "version": "1.0.3",
  "description": "Conformance test suite for OxDeAI Core implementations, ensuring compliance with the deterministic policy engine protocol through standardized test cases and validation tools.",
  "license": "Apache-2.0",
  "keywords": [
    "oxdeai",
    "conformance",
    "protocol",
    "verification",
    "deterministic",
    "test-vectors",
    "compliance",
    "audit",
    "snapshot",
    "envelope"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "extract": "pnpm build && node dist/scripts/extract-vectors.js",
    "validate": "pnpm build && node dist/src/validate.js"
  },
  "dependencies": {
    "@oxdeai/core": "^1.0.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
